# NewsRoom AI — Environment Variables
# Copy this file to .env and fill in your API keys

# --- REQUIRED ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# --- OPTIONAL ---
# GitHub Personal Access Token (increases rate limits; works without it on public repos)
GITHUB_TOKEN=

# GitHub Webhook Secret (set the same value in your GitHub repo webhook settings)
GITHUB_WEBHOOK_SECRET=newsroom_secret_2024

# Server settings
HOST=0.0.0.0
PORT=8000
