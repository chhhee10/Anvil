# QualityEngine AI — Environment Variables
# Copy this file to .env and fill in your API keys

# --- REQUIRED ---

# Google Gemini 2.0 Flash — Orchestrator, Self-Healer, Decision Agent
# Free: https://aistudio.google.com/apikey (1500 req/day)
GEMINI_API_KEY=your_gemini_key_here

# Groq Llama 3.3 70B — PR Reviewer, Security Scanner, Test Generator, Report Writer
# Free: https://console.groq.com (~14,400 req/day)
GROQ_API_KEY=your_groq_key_here

# Together AI — Fallback when Groq rate-limits
# Free $1 credit: https://api.together.ai
TOGETHER_API_KEY=your_together_key_here

# Tavily — Live web search / CVE enrichment (optional, brief alignment)
# Free: https://tavily.com (1000 searches/month)
TAVILY_API_KEY=your_tavily_key_here

# Omium — Observability & agent tracing (hackathon sponsor)
# Dashboard: https://app.omium.ai
OMIUM_API_KEY=your_omium_key_here

# --- GITHUB ---

# GitHub Personal Access Token (REQUIRED for autonomous merge/reject/issue)
# Needs scopes: repo, pull_requests, issues
# Generate: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Webhook secret — set the same value in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=qualityengine_secret_2026

# --- SERVER ---
HOST=0.0.0.0
PORT=8000
